generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js required tables ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- App tables ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // LeetCode credentials (session cookie, encrypted)
  lcSession      String?
  lcCsrfToken    String?
  lcUsername     String?
  accounts      Account[]
  sessions      Session[]
  notifications Notification[]
  submissions   Submission[]
}

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String  // "telegram" | "email"
  target  String  // chat_id or email address
  enabled Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  problemSlug String
  problemTitle String
  date        DateTime @default(now())
  status      String   // "accepted" | "wrong_answer" | "error" | "pending"
  runtime     String?
  memory      String?
  error       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
